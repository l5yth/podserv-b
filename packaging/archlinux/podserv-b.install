post_install() {
  getent group  podserv-b &>/dev/null || groupadd --system podserv-b
  getent passwd podserv-b &>/dev/null || \
    useradd --system --gid podserv-b --home-dir /srv/podcasts \
            --shell /sbin/nologin podserv-b
  chown podserv-b:podserv-b /srv/podcasts
  systemctl daemon-reload
  echo "  systemctl enable --now podserv-b"
}

post_upgrade() {
  post_install
}
